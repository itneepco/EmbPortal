@page
@model WebAdmin.Pages.Uoms.IndexModel

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-page="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Uoms[0].Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Uoms[0].Dimension)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Uoms[0].Created)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Uoms[0].CreatedBy)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Uoms[0].LastModified)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Uoms[0].LastModifiedBy)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Uoms) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Dimension)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Created)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.CreatedBy)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.LastModified)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.LastModifiedBy)
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-page="./Details" asp-route-id="@item.Id">Details</a> |
                <a asp-page="./Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
