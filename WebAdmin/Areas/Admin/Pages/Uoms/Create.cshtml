@page
@model CreateModel

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Uom</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Uom.Name" class="control-label"></label>
                <input asp-for="Uom.Name" class="form-control" required />
                <span asp-validation-for="Uom.Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Uom.Dimension" class="control-label"></label>
                <select asp-for="Uom.Dimension" asp-items="Html.GetEnumSelectList<UomDimension>()" class="form-control" required></select>
                <span asp-validation-for="Uom.Dimension" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
